{
  "version": 2,
  "buildCommand": "cd phase5-frontend && npm install",
  "outputDirectory": "phase5-frontend/.next",
  "installCommand": "cd phase5-frontend && npm install",
  "framework": "nextjs",
  "builds": [
    {
      "src": "phase5-frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "phase5-frontend/$1"
    }
  ]
}
